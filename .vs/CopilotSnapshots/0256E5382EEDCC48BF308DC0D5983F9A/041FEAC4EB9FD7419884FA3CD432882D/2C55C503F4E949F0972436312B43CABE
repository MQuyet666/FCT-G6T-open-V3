using OpenCvSharp; // Thêm thư viện OpenCvSharp
using HardwareTestApp.Domain.Models;

namespace HardwareTestApp.src.Infrastructure.Camera;

// Infrastructure/Camera/OpenCvCameraAdapter.cs
public class OpenCvCameraAdapter : ICameraService, IDisposable
{
    public event EventHandler<FrameReadyEventArgs> FrameReady;

    private VideoCapture _capture;
    private CancellationTokenSource _cts;
    private Task _captureTask;
    public bool IsRunning { get; private set; }

    public void StartPreview(CameraConfig config)
    {
        if (IsRunning) return;

        _capture = new VideoCapture(config.DeviceIndex);
        _capture.Set(CapProp.FrameWidth, config.Width);
        _capture.Set(CapProp.FrameHeight, config.Height);
        _capture.Set(CapProp.Fps, config.TargetFps);

        _cts = new CancellationTokenSource();
        IsRunning = true;

        // Chạy loop trên background thread
        _captureTask = Task.Run(() => CaptureLoop(_cts.Token));
    }

    private async Task CaptureLoop(CancellationToken ct)
    {
        using var mat = new Mat();
        while (!ct.IsCancellationRequested)
        {
            if (!_capture.Read(mat) || mat.Empty()) continue;

            // Convert Mat → Bitmap rồi raise event
            var bitmap = BitmapConverter.ToBitmap(mat);
            FrameReady?.Invoke(this, new FrameReadyEventArgs
            {
                Frame = bitmap,
                Timestamp = DateTime.Now
            });

            // Giới hạn ~30fps
            await Task.Delay(33, ct).ConfigureAwait(false);
        }
    }

    public void StopPreview()
    {
        _cts?.Cancel();
        _captureTask?.Wait(2000);
        _capture?.Dispose();
        IsRunning = false;
    }

    public async Task<Bitmap> CaptureFrameAsync()
    {
        using var mat = new Mat();
        await Task.Run(() => _capture.Read(mat));
        return BitmapConverter.ToBitmap(mat);
    }

    public void Dispose() => StopPreview();
}