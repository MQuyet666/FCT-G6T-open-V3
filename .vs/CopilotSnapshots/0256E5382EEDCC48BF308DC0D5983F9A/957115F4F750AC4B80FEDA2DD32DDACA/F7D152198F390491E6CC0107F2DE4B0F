        private void Mainform_Shown(object sender, EventArgs e)
        {
            if (_cameraPreview is not null)
            {
                _cameraPreview.BringToFront();
            }

            if (!_cameraPreviewService.IsRunning)
            {
                StartCameraPreview();
            }
        }

