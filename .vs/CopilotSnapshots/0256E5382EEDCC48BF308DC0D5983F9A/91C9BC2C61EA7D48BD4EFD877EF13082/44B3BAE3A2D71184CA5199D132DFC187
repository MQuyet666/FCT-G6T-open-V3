using HardwareTestApp.src.Application.Interfaces;
using HardwareTestApp.src.Domain.Interfaces;
using HardwareTestApp.src.Domain.Models;
using Microsoft.Extensions.Logging;
using System.Linq;

namespace HardwareTestApp.src.Application.Services;

public class SmokeDeviceTestService : ISmokeDeviceTestService
{
    private static readonly TimeSpan SetCalibTimeout = TimeSpan.FromSeconds(1);
    private static readonly TimeSpan PowerOnTimeout = TimeSpan.FromSeconds(1);
    private static readonly TimeSpan LedDetectTimeout = TimeSpan.FromSeconds(5);
    private static readonly TimeSpan ButtonTestTimeout = TimeSpan.FromSeconds(15);

    private readonly TestOrchestrator _testOrchestrator;
    private readonly IG6TAdapter _g6tAdapter;
    private readonly ICameraPreviewAppService _cameraPreview;
    private readonly ILogger<SmokeDeviceTestService> _logger;

    public SmokeDeviceTestService(
        TestOrchestrator testOrchestrator,
        IG6TAdapter g6tAdapter,
        ICameraPreviewAppService cameraPreview,
        ILogger<SmokeDeviceTestService> logger)
    {
        _testOrchestrator = testOrchestrator;
        _g6tAdapter = g6tAdapter;
        _cameraPreview = cameraPreview;
        _logger = logger;
    }

    public bool IsConnected => _g6tAdapter.IsConnected;

    public void Connect(string g6tComPort, int baudRate = 115200)
    {
        _g6tAdapter.Connect(g6tComPort, baudRate);
    }

    public void Disconnect()
    {
        _g6tAdapter.Disconnect();
    }

    public async Task<IReadOnlyList<TestStepResult>> RunStartSequenceAsync(string g6tComPort, Rectangle roi1, CancellationToken ct = default)
    {
        if (string.IsNullOrWhiteSpace(g6tComPort))
        {
            throw new ArgumentException("Chưa chọn G6T COM.", nameof(g6tComPort));
        }

        if (!_g6tAdapter.IsConnected)
        {
            _g6tAdapter.Connect(g6tComPort);
        }

        if (!_cameraPreview.IsRunning)
        {
            _cameraPreview.StartPreview();
        }

        var results = new List<TestStepResult>();

        var calibResult = await ExecuteCommandStepAsync(
            stepName: "Set Calib Pin",
            timeout: SetCalibTimeout,
            commandFunc: token => _testOrchestrator.SetCalibPinAsync(true, token),
            expectedCommandId: G6TCommandId.SetCalibPin,
            ct: ct).ConfigureAwait(false);
        results.Add(calibResult);
        if (!calibResult.IsPassed)
        {
            return results;
        }

        var powerResult = await ExecuteCommandStepAsync(
            stepName: "Cấp nguồn",
            timeout: PowerOnTimeout,
            commandFunc: token => _testOrchestrator.PowerOnAsync(token),
            expectedCommandId: G6TCommandId.PowerControl,
            ct: ct).ConfigureAwait(false);
        results.Add(powerResult);
        if (!powerResult.IsPassed)
        {
            return results;
        }

        var ledDetectResult = await DetectLedColorsAsync(roi1, LedDetectTimeout, ct).ConfigureAwait(false);
        results.Add(ledDetectResult);

        var ledTestPassed = calibResult.IsPassed && powerResult.IsPassed && ledDetectResult.IsPassed;
        results.Add(new TestStepResult
        {
            StepName = "LED Test",
            IsPassed = ledTestPassed,
            Message = ledTestPassed ? "PASS LED Test" : "FAIL LED Test",
        });

        if (!ledTestPassed)
        {
            return results;
        }

        var buttonTestResult = await ExecuteCommandStepAsync(
            stepName: "Button Test",
            timeout: ButtonTestTimeout,
            commandFunc: token => _testOrchestrator.TestButtonBuzzerAsync(token),
            expectedCommandId: G6TCommandId.TestButton,
            ct: ct).ConfigureAwait(false);
        results.Add(buttonTestResult);

        return results;
    }

    private async Task<TestStepResult> ExecuteCommandStepAsync(
        string stepName,
        TimeSpan timeout,
        Func<CancellationToken, Task<G6TResponse>> commandFunc,
        G6TCommandId expectedCommandId,
        CancellationToken ct)
    {
        using var timeoutCts = CancellationTokenSource.CreateLinkedTokenSource(ct);
        timeoutCts.CancelAfter(timeout);

        try
        {
            var response = await commandFunc(timeoutCts.Token).ConfigureAwait(false);
            var passed = response.IsSuccess && response.CommandId == expectedCommandId;
            var message = passed
                ? $"{stepName}: ACK thành công ({response.CommandId}) | TX[{response.ComPort}]={ToHex(response.TxFrame)} | RX[{response.ComPort}]={ToHex(response.RxFrame)}"
                : $"{stepName}: ACK thất bại. Command={response.CommandId}, Status={response.Status} | TX[{response.ComPort}]={ToHex(response.TxFrame)} | RX[{response.ComPort}]={ToHex(response.RxFrame)}";

            _logger.LogInformation("{Message}", message);
            return new TestStepResult
            {
                StepName = stepName,
                IsPassed = passed,
                Message = message,
            };
        }
        catch (OperationCanceledException)
        {
            var message = $"{stepName}: timeout {timeout.TotalSeconds:0.#}s";
            _logger.LogWarning("{Message}", message);
            return new TestStepResult
            {
                StepName = stepName,
                IsPassed = false,
                Message = message,
            };
        }
        catch (InvalidDataException ex)
        {
            var message = $"{stepName}: frame lỗi - {ex.Message}";
            _logger.LogWarning("{Message}", message);
            return new TestStepResult
            {
                StepName = stepName,
                IsPassed = false,
                Message = message,
            };
        }

    private static string ToHex(byte[] data)
    {
        if (data is null || data.Length == 0)
        {
            return "<empty>";
        }

        return string.Join(" ", data.Select(x => x.ToString("X2")));
    }
    }

    private async Task<TestStepResult> DetectLedColorsAsync(Rectangle roi1, TimeSpan timeout, CancellationToken ct)
    {
        using var timeoutCts = CancellationTokenSource.CreateLinkedTokenSource(ct);
        timeoutCts.CancelAfter(timeout);

        var redDetected = false;
        var greenDetected = false;

        while (!timeoutCts.IsCancellationRequested)
        {
            using var frame = await _cameraPreview.CaptureFrameAsync().ConfigureAwait(false);
            var boundedRoi = Rectangle.Intersect(new Rectangle(Point.Empty, frame.Size), roi1);
            if (boundedRoi.Width <= 0 || boundedRoi.Height <= 0)
            {
                return new TestStepResult
                {
                    StepName = "LED ROI Detect",
                    IsPassed = false,
                    Message = "ROI1 nằm ngoài khung ảnh.",
                };
            }

            AnalyzeColors(frame, boundedRoi, ref redDetected, ref greenDetected);
            if (redDetected && greenDetected)
            {
                var passMessage = "LED ROI Detect: phát hiện đủ màu đỏ và xanh.";
                _logger.LogInformation("{Message}", passMessage);
                return new TestStepResult
                {
                    StepName = "LED ROI Detect",
                    IsPassed = true,
                    Message = passMessage,
                };
            }

            try
            {
                await Task.Delay(100, timeoutCts.Token).ConfigureAwait(false);
            }
            catch (OperationCanceledException)
            {
                break;
            }
        }

        return new TestStepResult
        {
            StepName = "LED ROI Detect",
            IsPassed = false,
            Message = $"LED ROI Detect: không thấy đủ đỏ + xanh trong {timeout.TotalSeconds:0.#}s.",
        };
    }

    private static void AnalyzeColors(Bitmap frame, Rectangle roi, ref bool redDetected, ref bool greenDetected)
    {
        const int sampleStep = 4;

        for (var y = roi.Top; y < roi.Bottom; y += sampleStep)
        {
            for (var x = roi.Left; x < roi.Right; x += sampleStep)
            {
                var color = frame.GetPixel(x, y);

                if (!redDetected && color.R > 180 && color.G < 120 && color.B < 120)
                {
                    redDetected = true;
                }

                if (!greenDetected && color.G > 150 && color.R < 150 && color.B < 150)
                {
                    greenDetected = true;
                }

                if (redDetected && greenDetected)
                {
                    return;
                }
            }
        }
    }
}
